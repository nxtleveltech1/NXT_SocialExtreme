# Core
DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require"

# Token encryption (32 bytes, base64 or hex). Example below is 32 bytes base64:
TOKEN_ENCRYPTION_KEY="AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
JOB_RUNNER_SECRET=""

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Meta (Facebook/Instagram/WhatsApp Business) OAuth
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="http://localhost:3000/api/oauth/meta/callback"
META_WEBHOOK_VERIFY_TOKEN=""

# WhatsApp Business API (Meta - Optional)
WHATSAPP_BUSINESS_PHONE_NUMBER="+27 76 147 8369"
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""

# WhatsApp Cloud API (Direct Meta API - Alternative to Business Manager)
