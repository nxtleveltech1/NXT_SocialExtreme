# MessageBird WhatsApp API (Alternative)
MESSAGEBIRD_API_KEY=""
MESSAGEBIRD_CHANNEL_ID=""

# Third-Party WhatsApp Provider (e.g., Unipile, Whatsboost)
WHATSAPP_PROVIDER=""
WHATSAPP_PROVIDER_API_KEY=""
WHATSAPP_PROVIDER_API_URL=""

# Meta Pixel (for Conversions API)
META_PIXEL_ID=""

# Meta Business Account (for Commerce API)
