# Vercel Blob (media storage for social publishing)
# Get your token at https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=""

# App URL (used for OpenRouter referer header)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

