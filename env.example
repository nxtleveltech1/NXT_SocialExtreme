# Meta Ad Account (for Marketing API)
META_AD_ACCOUNT_ID=""

# TikTok OAuth
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="http://localhost:3000/api/oauth/tiktok/callback"

# OpenRouter (AI content generation - OpenAI-compatible gateway)
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# Optional: Override default model (see https://openrouter.ai/models)
# Examples: google/gemini-2.0-flash-001, openai/gpt-4-turbo, anthropic/claude-3-sonnet
OPENROUTER_MODEL=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# OpenAI
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_DEFAULT_MODEL="gpt-4.1-mini"

# Anthropic
ANTHROPIC_API_KEY=""
ANTHROPIC_DEFAULT_MODEL="claude-3-5-haiku-latest"

# Google Gemini
GEMINI_API_KEY=""
GEMINI_DEFAULT_MODEL="gemini-2.0-flash"

# Krev AI
KREV_API_KEY=""
KREV_API_BASE_URL="https://api.krev.ai"
KREV_TEXT_ENDPOINT="/v1/text"
KREV_IMAGE_ENDPOINT="/v1/images"
KREV_VIDEO_ENDPOINT="/v1/videos"

# Generic OpenAI-compatible provider
GENERIC_AI_API_KEY=""
GENERIC_AI_BASE_URL=""
