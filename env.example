WHATSAPP_CLOUD_API_ACCESS_TOKEN=""
WHATSAPP_CLOUD_API_APP_ID=""
WHATSAPP_CLOUD_API_APP_SECRET=""

# Twilio WhatsApp API (Recommended Alternative)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
